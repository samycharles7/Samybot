const axios = require("axios");
const fs = require("fs-extra");
const path = require("path");

module.exports.config = {
  name: "hvideo",
  aliases: ["hentaivideo", "nsfwvid"],
  version: "1.0.0",
  author: "AI",
  role: 0,
  description: "Envoie une vidéo anime NSFW aléatoire",
  category: "nsfw",
  countDown: 15, // Plus long car les vidéos prennent du temps à charger
  guide: {
    en: "{pn}"
  }
};

module.exports.onStart = async function ({ message, event }) {
  await message.reaction("⏳", event.messageID);

  try {
    // Utilisation d'un endpoint de votre API habituelle pour les vidéos hentai
    // Si cet endpoint change, vous n'aurez qu'à modifier l'URL ci-dessous
    const apiUrl = "https://www.noobs-apis.run.place/nazrul/hentai-video";
    
    const res = await axios.get(apiUrl);
    const videoUrl = res.data.url || res.data.video_url || res.data.data?.url;

    if (!videoUrl) {
      return message.reply("❌ Impossible de trouver une vidéo pour le moment.");
    }

    // Préparation du dossier cache
    const cacheDir = path.join(__dirname, "cache");
    if (!fs.existsSync(cacheDir)) fs.ensureDirSync(cacheDir);

    const fileName = `hvideo_${Date.now()}.mp4`;
    const filePath = path.join(cacheDir, fileName);

    // Téléchargement de la vidéo par flux (stream)
    const response = await axios({
      method: 'get',
      url: videoUrl,
      responseType: 'stream'
    });

    const writer = fs.createWriteStream(filePath);
    response.data.pipe(writer);

    // Attendre que le téléchargement soit fini
    await new Promise((resolve, reject) => {
      writer.on('finish', resolve);
      writer.on('error', reject);
    });

    // Vérification de la taille (Messenger limite souvent à 25MB)
    const stats = fs.statSync(filePath);
    const fileSizeInBytes = stats.size;
    const fileSizeInMegabytes = fileSizeInBytes / (1024 * 1024);

    if (fileSizeInMegabytes > 25) {
      fs.unlinkSync(filePath);
      return message.reply("❌ La vidéo est trop lourde pour être envoyée sur Messenger (> 25MB).");
    }

    await message.reaction("✅", event.messageID);

    // Envoi de la vidéo
    await message.reply({
      body: `🔞 Vidéo Hentai Aléatoire\nDemandée par : ${event.senderID}`,
      attachment: fs.createReadStream(filePath)
    });

    // Suppression du fichier après l'envoi
    setTimeout(() => {
      if (fs.existsSync(filePath)) fs.unlinkSync(filePath);
    }, 20000);

  } catch (e) {
    console.error(e);
    message.reaction("❌", event.messageID);
    message.reply("❌ Une erreur est survenue lors de la récupération de la vidéo. L'API est peut-être hors ligne.");
  }
};